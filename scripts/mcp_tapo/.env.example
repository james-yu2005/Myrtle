# Copy to .env and fill in your values:
#   cp .env.example .env

# From xiaozhi.me console → your agent → MCP endpoint (WebSocket URL with token).
MCP_ENDPOINT=wss://api.xiaozhi.me/mcp/?token=YOUR_TOKEN_HERE

# TP-Link / Tapo account — exact same email/password as the Tapo app.
# Email is case-sensitive for KLAP auth (James... ≠ james...).
# Enable Third-Party Compatibility first:
#   Tapo → Me → Third-Party Services → Third-Party Compatibility
KASA_USERNAME=you@example.com
KASA_PASSWORD=your-tapo-password

# Bulb IPv4 on your LAN (Tapo app device info, or `kasa discover`).
# Prefer a DHCP reservation so this stays stable.
TAPO_HOST=192.168.1.50
